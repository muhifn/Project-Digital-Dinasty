# ==============================================================================
# Planet Motor BMW API - Environment Variables
# ==============================================================================
# Copy this file to .env for local development.
# Production values should be configured in the hosting dashboard.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database - PostgreSQL / Supabase (required)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/planet_motor_bmw?sslmode=disable"

# ------------------------------------------------------------------------------
# JWT secret (required)
# ------------------------------------------------------------------------------
# Used to sign access and refresh tokens.
# Generate with: openssl rand -base64 64
JWT_SECRET="your-jwt-secret-here-generate-with-openssl-rand-base64-64"

# ------------------------------------------------------------------------------
# Server configuration
# ------------------------------------------------------------------------------
# Keep 8080 for local development.
PORT=8080

# Comma-separated allowed frontend origins.
CORS_ORIGINS="http://localhost:3000"
