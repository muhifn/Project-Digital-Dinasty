# ==============================================================================
# Planet Motor BMW Frontend - Environment Variables
# ==============================================================================
# Copy this file to .env.local for local development.
# Production values should be configured in the hosting dashboard.
# ==============================================================================

# ------------------------------------------------------------------------------
# App configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Planet Motor BMW"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# Go API backend
# ------------------------------------------------------------------------------
# Local development:
GO_API_URL="http://localhost:8080"

# Production:
# Set GO_API_URL to the active backend API base URL in the hosting dashboard.
